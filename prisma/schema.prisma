generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum InviteType {
  LIBRARY
  DIRECT
}

model Invite {
  id              String     @id @default(cuid())
  token           String     @unique @default(uuid())
  pin             String     // bcrypt-hashed
  label           String?
  type            InviteType
  allowedSections String?    // comma-separated Plex section IDs (null = all)
  ratingKey       String?    // for DIRECT type
  maxUses         Int?
  useCount        Int        @default(0)
  expiresAt       DateTime?
  active          Boolean    @default(true)
  createdAt       DateTime   @default(now())
  sessions        Session[]
}

model Session {
  id        String   @id @default(cuid())
  inviteId  String
  invite    Invite   @relation(fields: [inviteId], references: [id], onDelete: Cascade)
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  expiresAt DateTime
}
